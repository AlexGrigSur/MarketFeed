{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "StockQuoteRepository": "Host=localhost;Port=5432;Database=market_feed;Username=postgres;Password=postgres"
    },
    "StockExchangeProcessor": {
        "ChannelMaxSize": 10000,
        "BatchSize": 1000,
        "SaveInterval": "00:01:00",
        "SaveRetry": {
            "MaxRetryAttempts": 3,
            "Delay": "00:00:00.200",
            "MaxDelay": "00:00:05"
        }
    },
    "Metrics": {
