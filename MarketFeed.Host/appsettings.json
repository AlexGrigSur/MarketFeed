    },
    "Exchanges": [
        {
            "ExchangeType": "ExchangeA",
            "InstanceName": "ExchangeA",
            "Endpoint": "ws://localhost:5008/ws",
            "Tickers": []
        },
        {
            "ExchangeType": "ExchangeA",
            "InstanceName": "ExchangeA-AAPL",
            "Endpoint": "ws://localhost:5008/ws",
            "Tickers": [ "AAPL" ]
        },
        {
            "ExchangeType": "ExchangeB",
            "InstanceName": "ExchangeB",
            "Endpoint": "ws://localhost:5073/ws",
            "AuthToken": "secret-token",
            "Tickers": []
        }
    ],
    "AllowedHosts": "*"
}
